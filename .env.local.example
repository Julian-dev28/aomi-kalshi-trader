# ── AOMI ─────────────────────────────────────────────────────────────────────
# Public AOMI backend — no API key required for the default app
AOMI_BASE_URL=https://api.aomi.dev
AOMI_APP=default

# ── Kalshi ────────────────────────────────────────────────────────────────────
# Get your API key and RSA key pair at https://kalshi.com/settings/api
KALSHI_API_KEY=your-kalshi-api-key-id
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem
