# ── AOMI ─────────────────────────────────────────────────────────────────────
# Uses the AOMI Hyperliquid app (Open access, works server-side)
AOMI_BASE_URL=https://api.aomi.dev
AOMI_APP=hyperliquid

# ── Hyperliquid ───────────────────────────────────────────────────────────────
# Your Hyperliquid wallet (EVM address + private key for signing perp orders)
HYPERLIQUID_WALLET_ADDRESS=0x...your-wallet-address
HYPERLIQUID_PRIVATE_KEY=0x...your-private-key
NEXT_PUBLIC_HL_WALLET=0x...your-wallet-address
